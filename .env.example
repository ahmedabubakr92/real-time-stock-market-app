NODE_ENV='development'

# Your app's public URL (http://localhost:3000 in dev, your Vercel URL in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
# Same as NEXT_PUBLIC_BASE_URL
BETTER_AUTH_URL=http://localhost:3000

# Google Gemini API key — https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Inngest — set to 1 in development ONLY, omit entirely in production
INNGEST_DEV=1

# Gmail address and App Password for sending emails
# App Passwords: https://support.google.com/accounts/answer/185833
NODEMAILER_EMAIL=your-email@gmail.com
NODEMAILER_PASSWORD=your-gmail-app-password

# Finnhub API key — https://finnhub.io (free tier works)
FINNHUB_API_KEY=your-finnhub-api-key
